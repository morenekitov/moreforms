APP_DOMAIN=app.moreforms.ru
STREAMLIT_PORT=8501

OPENCLAW_RESPONSES_URL=http://openclaw-gateway:18789/v1/responses
OPENCLAW_GATEWAY_TOKEN=replace-me
OPENCLAW_AGENT_ID=main
OPENCLAW_CHAT_USER_PREFIX=team

OPENCLAW_IMAGE=openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONFIG_DIR=/srv/moreforms/runtime/openclaw/config
OPENCLAW_WORKSPACE_DIR=/srv/moreforms/runtime/openclaw/workspace
GOG_KEYRING_PASSWORD=replace-me
XDG_CONFIG_HOME=/home/node/.config

OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64
OAUTH2_PROXY_ALLOWED_EMAILS_FILE=/srv/moreforms/runtime/secrets/oauth2-allowed-emails.txt

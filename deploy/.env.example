APP_DOMAIN=app.moreforms.ru

POSTGRES_DB=moreforms
POSTGRES_USER=moreforms
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql+psycopg://moreforms:replace-me@postgres:5432/moreforms

APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
SQL_ECHO=false
AUTO_CREATE_SCHEMA=false

AUTH_DISABLED=false
ALLOWED_EMAILS=
BOOTSTRAP_OWNER_EMAIL=owner@example.com

STREAMLIT_API_BASE_URL=http://api:8000
STREAMLIT_SERVER_PORT=8501

OAUTH2_PROXY_CLIENT_ID=replace-me
OAUTH2_PROXY_CLIENT_SECRET=replace-me
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-char-secret
OAUTH2_PROXY_ALLOWED_EMAILS_FILE=/srv/moreforms/runtime/secrets/oauth2-allowed-emails.txt
